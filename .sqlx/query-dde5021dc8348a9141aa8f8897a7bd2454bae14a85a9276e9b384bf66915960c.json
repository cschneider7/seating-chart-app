  "query": "SELECT\n            t.id as \"table_id!\",\n            s.position,\n            s.student_id as \"student_id!\"\n        FROM tables t\n        INNER JOIN seats s ON (t.id = s.table_id)\n        WHERE t.classroom_id = $1 AND s.student_id IS NOT NULL\n        ORDER BY t.table_number, s.position\n        ",
