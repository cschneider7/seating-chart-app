{
  "db_name": "PostgreSQL",
  "query": "SELECT\n            t.table_number,\n            t.x_pos,\n            t.y_pos,\n            ARRAY_AGG(s.student_id ORDER BY s.seat_number) as \"seat_assignments!: Vec<Option<Uuid>>\"\n        FROM tables t\n        INNER JOIN seats s ON (t.id = s.table_id)\n        WHERE t.classroom_id = $1\n        GROUP BY t.table_number, t.x_pos, t.y_pos\n        ",
